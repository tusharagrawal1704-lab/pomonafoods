{
  "name": "SubscriptionPlan",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "monthly_price": {
      "type": "number"
    },
    "order_threshold": {
      "type": "number"
    },
    "paid_orders": {
      "type": "number"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "monthly_price",
    "order_threshold",
    "paid_orders"
  ]
}