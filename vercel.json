{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["server/epicurean.db"]
      }
    },
    {
      "src": "server/version.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/version",
      "destination": "/server/version.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/server/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
